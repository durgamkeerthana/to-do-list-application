<div class="container">
  <h1 class="title">Todo List</h1>

  <%= form_with(model: @task, local: true) do |form| %>
    <div class="form-group">
      <%= form.text_field :title, placeholder: "New task...", class: "input" %>
      <%= form.datetime_select :due_time, class: "input" %>
      <%= form.submit "Add", class: "btn" %>
    </div>
  <% end %>

  <% if @grouped_tasks.present? %>
    <h2 style="margin-top: 30px;">Tasks Grouped by Month</h2>
    <% @grouped_tasks.each do |label, tasks| %>
      <h3 style="margin-top: 20px; color: #555;"><%= label %></h3>
      <ul class="task-list">
        <% tasks.each do |task| %>
          <li class="task-item <%= 'completed' if task.completed %>">
            <div>
              <strong>📝 <%= task.title %></strong>

              <% if task.due_time.present? %>
                <p>🕒 Due by: <%= task.due_time.strftime("%d %b %Y %I:%M %p") %></p>
              <% end %>

              <% if task.completed? %>
                <p style="color: green;">✔ Completed</p>
              <% else %>
                <p style="color: red;">⏳ Pending</p>
              <% end %>
            </div>

            <div class="actions">
              <%= button_to 'Toggle', toggle_task_path(task), method: :patch, class: "btn small" %>
              <%= link_to 'Edit', edit_task_path(task), class: "btn small" %>
              <%= button_to 'Delete', task_path(task), method: :delete, data: { confirm: 'Are you sure?' }, class: "btn small danger" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% else %>
    <p>No tasks available.</p>
  <% end %>

  <% if @tasks.present? %>
    <h2 style="margin-top: 30px;">All Tasks (Detailed View)</h2>
    <% @tasks.each do |task| %>
      <div class="task-details" style="border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; border-radius: 5px;">
        
        <p><strong>📝 <%= task.title %></strong></p>

        <% if task.due_time.present? %>
          <p>🕒 Due by: <%= task.due_time.strftime("%d %b %Y %I:%M %p") %></p>
        <% end %>

        <% if task.completed? %>
          <p style="color: green;">✔ Completed</p>
          <% if task.completed_at.present? %>
            <p style="color: green;">Completed at: <%= task.completed_at.strftime("%d %b %Y %I:%M %p") %></p>
          <% end %>
        <% else %>
          <p style="color: red;">⏳ Pending</p>
        <% end %>

        <% if task.tagline.present? %>
          <p style="color: orange;"><em>💡 <%= task.tagline %></em></p>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
